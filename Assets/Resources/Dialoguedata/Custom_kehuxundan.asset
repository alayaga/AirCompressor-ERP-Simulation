  lines:
  - speakerName: "\u7535\u8111\u663E\u793A"
    text: "\u3010\u5BA2\u6237\u5B9A\u5236\u9700\u6C42\u3011\uFF1A\u9700\u8981\u975E\u6807\u5B9A\u5236\u7A7A\u538B\u673A"
  - speakerName: "\u9500\u552E\u5458"
    text: "\u4E0E\u5BA2\u6237\u8054\u7CFB\uFF1A\n\u201C\u60A8\u597D\uFF0C\u6211\u548C\u60A8\u786E\u8BA4\u4E00\u4E0B\u5B9A\u5236\u53C2\u6570\u3002\u201D"
  - speakerName: "\u5BA2\u6237"
    text: "\u7ED9\u51FA\u5B9A\u5236\u53C2\u6570\u3002\u3002\u3002"
  - speakerName: "\u9500\u552E\u5458"
    text: "\u201C\u538B\u529B\u3001\u6D41\u91CF\u3001\u7279\u6B8A\u914D\u7F6E\u5DF2\u9010\u9879\u6838\u5BF9\u5B8C\u6BD5\u3002\u201D"
  - speakerName: "\u9500\u552E\u5458"
    text: "\u201C\u5B9A\u5236\u9700\u6C42\u5DF2\u786E\u8BA4\uFF0C\u5C06\u4E3A\u60A8\u5B89\u6392\u4E13\u5C5E\u751F\u4EA7\u3002\u201D"
  - speakerName: "\u7535\u8111\u663E\u793A"
    text: "\u3010\u5B9A\u5236\u8BA2\u5355\u5DF2\u751F\u6210\u3011"
  completeStepOnEnd: 1
