# =============================================================================
# Unity .gitignore - 完整版本
# 适用于 Unity 2019+ 和 Gitee/GitHub
# =============================================================================

# =============================================================================
# 1. Unity 自动生成的文件夹（必须忽略）
# =============================================================================
[Ll]ibrary/
[Tt]emp/
[Tt]mp/
[Bb]uild/
[Bb]uilds/
[Oo]bj/
[Ll]ogs/
[Mm]emoryCaptures/
[U]pgradeLog*

# Unity 2020+ 新增
[Dd]erivedData/
*.log

# =============================================================================
# 2. 个人编辑器设置（避免团队冲突）
# =============================================================================
[Uu]ser[Ss]ettings/
[Ll]ocal/[Tt]emp/
*.prefs
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb.meta
*.mdb.meta
*.opendb
*.VC.db

# =============================================================================
# 3. IDE 和编辑器文件（可选，根据团队习惯）
# =============================================================================
# Visual Studio
.vs/
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj

# Visual Studio Code
.vscode/

# JetBrains Rider
.idea/
*.iml
*.rider
[Aa]ssets/Plugins/Editor/JetBrains*

# MonoDevelop/Xamarin
*.pidb.meta
*.sln.meta

# =============================================================================
# 4. 操作系统文件
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# =============================================================================
# 5. 构建产物和发布文件
# =============================================================================
*.apk
*.aab
*.ipa
*.exe
*.dll
*.app
*.xapk
*.unitypackage
*.jar
*.war
*.ear

# WebGL
*.webgl

# =============================================================================
# 6. 版本控制和备份文件
# =============================================================================
*.orig
*.bak
*.swp
*.swo
*~
.cache
*.cache

# =============================================================================
# 7. 包管理器和依赖
# =============================================================================
# Unity Package Manager
Packages/manifest.json.lock
Packages/packages-lock.json.meta

# Node.js (如果使用 WebGL 或工具链)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Gradle (Android)
.gradle/
gradle-app.setting
!gradle-wrapper.jar

# =============================================================================
# 8. 测试和覆盖率报告
# =============================================================================
[Tt]est[Rr]esult*
[Nn]unit*
[Cc]overage*
*.coverage
*.coveragexml
*.lcov

# =============================================================================
# 9. 文档生成
# =============================================================================
[Dd]oc/
[Dd]ocs/
html/
xml/

# =============================================================================
# 10. 敏感信息和配置
# =============================================================================
# 环境变量
.env
.env.local
.env.*.local

# 密钥和配置文件
**/secrets.*
**/config.private.*
**/appsettings.Production.json
**/appsettings.Development.json

# API 密钥文件
*.key
*.pem
*.cert

# =============================================================================
# 11. 第三方服务和插件
# =============================================================================
# Crashlytics/Firebase
crashlytics-build.properties
fabric.properties
google-services.json
GoogleService-Info.plist

# Analytics
*.analytics

# Ads
admob.json

# =============================================================================
# 12. Unity 特定文件
# =============================================================================
# Asset Store 工具（可选）
# [Aa]ssets/AssetStoreTools*

# TextMesh Pro（如果不需要版本控制）
# [Aa]ssets/TextMesh*Pro/

# Shader 缓存
[Dd]ata*/

# Unity Hub 设置
UnityHub/

# =============================================================================
# 13. 压缩和归档文件
# =============================================================================
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.tgz

# =============================================================================
# 14. 调试和诊断文件
# =============================================================================
sysinfo.txt
crash*.dmp
*.dmp

# =============================================================================
# 15. 性能分析文件
# =============================================================================
*.profiler
*.profile
*.trace

# =============================================================================
# 16. 临时和缓存文件
# =============================================================================
*.tmp
*.temp
*.swp
*.swo
*~
.cache
*.cache

# =============================================================================
# 17. 导出和导入文件
# =============================================================================
ExportedObj/
.consulo/

# =============================================================================
# 18. 其他常见文件
# =============================================================================
# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Ruby
*.gem
*.lock

# Java
*.class
*.jar
*.war
*.ear

# =============================================================================
# 重要：不要忽略这些文件！
# =============================================================================
# ✅ 必须保留：
# - Assets/ 文件夹及其所有 .meta 文件
# - ProjectSettings/ 文件夹
# - Packages/manifest.json（包管理器配置）
# - .gitignore 本身
# - README.md 等文档

# 强制保留 Assets 的 .meta 文件（即使上面有忽略规则）
!/[Aa]ssets/**/*.meta
!/[Pp]roject[Ss]ettings/**/*.meta
!/[Pp]ackages/**/*.meta